FROM debian:bullseye-slim
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get clean && apt-get update && apt-get -y upgrade
RUN apt-get -y install vim xterm git build-essential python3 sqlite3 zram-tools systemd systemd-sysv \
    nano python3-setuptools python3-wheel tcpdump apt-utils cron init logrotate make \
    python3-numpy python3-pandas python3-six python3-yaml python3-matplotlib tk fim
COPY ./examples /home/root/Workspace
RUN mkdir  /home/root/repo
WORKDIR /home/root/
# We set env, as this gets extracted by Webvm. This is optional.
ENV HOME="/home/root" TERM="xterm" USER="root" SHELL="/bin/bash" EDITOR="vim" LANG="en_US.UTF-8" LC_ALL="C"
RUN gcc --version
RUN python3 --version
RUN vim --version
RUN git --version
CMD [ "/bin/bash" ]
